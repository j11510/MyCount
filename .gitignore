# =======================
# MyCount .gitignore
# =======================

# Environments (.env 중요 데이터 보호)
.env
.env.*
.venv
env/
venv/
ENV/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
build/
develop-eggs/
dist/
downloads/
eggs/
# lib/ and lib64/ removed to allow frontend/src/lib

parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Databases
*.db
*.sqlite3
mycount.db

# Node.js / Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/

# OS/Editor
.DS_Store
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Documents & Media (Exclude as requested)
*.xlsx
*.xls
*.docx
*.doc
*.hwp
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg
*.pdf
월별보고_extracted.txt
